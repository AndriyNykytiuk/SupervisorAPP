                        "method": "GET",
                        "url": "{{baseUrl}}/api/detachments"
                    }
                },
                {
                    "name": "Get Detachment by ID (GOD: any, SEMI-GOD: own only)",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/detachments/1"
                    }
                },
                {
                    "name": "Create Detachment (GOD only)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/detachments",
                        "header": [
                            {
                                "key": "Content-Type",
