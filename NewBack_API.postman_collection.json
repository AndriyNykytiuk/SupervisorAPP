{
    "info": {
        "_postman_id": "newback-api-collection",
        "name": "NewBack API",
        "description": "Full API collection for the NewBack project with role-based access control.\n\nRoles:\n• GOD — full access to everything\n• SEMI-GOD — read-only: own detachment + brigades + tests in own detachment\n• RW — read/write tests only for own brigade\n\nLogin-only API — users are pre-created via seed. Login with any user to auto-save the Bearer token. The response includes the user's role, brigade, and detachment automatically.",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        {
            "key": "baseUrl",
            "value": "http://localhost:3000",
            "description": "Set to http://localhost:3000 for local dev OR https://supervisorapp.onrender.com for production"
        },
        {
            "key": "token",
            "value": ""
        }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [
            {
                "key": "token",
                "value": "{{token}}",
                "type": "string"
            }
        ]
    },
    "item": [
        {
            "name": "Auth",
            "item": [
                {
                    "name": "Login",
                    "event": [
                        {
                            "listen": "test",
                            "script": {
                                "exec": [
                                    "const res = pm.response.json();",
                                    "if (res.token) {",
                                    "    pm.collectionVariables.set('token', res.token);",
                                    "    console.log('Token saved ✅');",
                                    "    console.log('Role: ' + res.user.role);",
                                    "    console.log('Brigade: ' + (res.user.brigadeName || 'none'));",
                                    "    console.log('Detachment: ' + (res.user.detachmentName || 'none'));",
                                    "}"
                                ]
                            }
                        }
                    ],
                    "request": {
                        "auth": {
                            "type": "noauth"
                        },
                        "method": "POST",
                        "url": "{{baseUrl}}/api/auth/login",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"afryca\",\n  \"password\": \"qwerty\"\n}"
                        }
                    }
                }
            ]
        },
        {
            "name": "Users",
            "item": [
                {
                    "name": "Get All Users",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/users"
                    }
                },
                {
                    "name": "Get User by ID",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/users/1"
                    }
                },
                {
                    "name": "Create User (GOD only)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/users",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"testuser\",\n  \"password\": \"123456\",\n  \"role\": \"RW\",\n  \"brigadeId\": 1\n}"
                        }
                    }
                },
                {
                    "name": "Update User (GOD only)",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/api/users/1",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"updatedName\",\n  \"role\": \"SEMI-GOD\",\n  \"brigadeId\": 2\n}"
                        }
                    }
                },
                {
                    "name": "Delete User (GOD only)",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/api/users/1"
                    }
                }
            ]
        },
        {
            "name": "Detachments",
            "description": "GOD: full CRUD | SEMI-GOD: read own detachment only | RW: 403 blocked",
            "item": [
                {
                    "name": "Get All Detachments (GOD: all, SEMI-GOD: own only)",
