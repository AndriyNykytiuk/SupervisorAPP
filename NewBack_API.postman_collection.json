        {
            "name": "Test Items",
            "description": "GOD: full CRUD | SEMI-GOD: read own detachment | RW: CRUD own brigade only. Items belong to a testList + brigade.",
            "item": [
                {
                    "name": "Get All Test Items (scoped by role)",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/test-items"
                    }
                },
                {
                    "name": "Get Test Items by Brigade (grouped by TestList)",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/test-items/brigade/1",
                        "description": "Returns all test lists with their test items filtered by brigade. Response: [ { testList, TestItems: [...] }, ... ]"
                    }
                },
                {
                    "name": "Get Test Items by Brigade + TestList",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/test-items/brigade/1/test-list/1"
                    }
                },
                {
                    "name": "Get Test Item by ID",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/api/test-items/1"
                    }
                },
                {
                    "name": "Create Test Item",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/api/test-items",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Pressure Test\",\n  \"result\": \"pass\",\n  \"notes\": \"All values OK\",\n  \"testListId\": 1,\n  \"brigadeId\": 1\n}"
                        }
                    }
                },
                {
                    "name": "Update Test Item (all fields)",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/api/test-items/1",
                        "header": [
                            {
