                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Detachment Gamma\"\n}"
                        }
                    }
                },
                {
                    "name": "Update Detachment (GOD only)",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/api/detachments/1",
                        "header": [
                            {
                                "key": "Content-Type",
                                "value": "application/json"
                            }
                        ],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Detachment Alpha Updated\"\n}"
                        }
                    }
                },
                {
                    "name": "Delete Detachment (GOD only)",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/api/detachments/1"
                    }
                }
            ]
        },
