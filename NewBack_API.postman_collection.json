                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Updated Name\",\n  \"result\": \"fail\",\n  \"notes\": \"Updated notes\",\n  \"testListId\": 1,\n  \"brigadeId\": 1\n}"
                        }
                    }
