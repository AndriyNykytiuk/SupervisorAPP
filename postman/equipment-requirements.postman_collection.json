{
    "info": {
        "name": "Equipment Requirements API",
        "description": "CRUD API for vehicle types, equipment items, and equipment availability",
        "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
    },
    "variable": [
        { "key": "baseUrl", "value": "http://localhost:3000/api" },
        { "key": "token", "value": "YOUR_JWT_TOKEN_HERE" }
    ],
    "auth": {
        "type": "bearer",
        "bearer": [{ "key": "token", "value": "{{token}}" }]
    },
    "item": [
        {
            "name": "Vehicle Types",
            "item": [
                {
                    "name": "Get All Vehicle Types",
                    "request": {
                        "method": "GET",
                        "url": "{{baseUrl}}/vehicle-types",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
                    }
                },
                {
                    "name": "Create Vehicle Type (GOD)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/vehicle-types",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Автоцистерна\"\n}"
                        }
                    }
                },
                {
                    "name": "Delete Vehicle Type (GOD)",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/vehicle-types/1",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
                    }
                }
            ]
        },
        {
            "name": "Equipment Items",
            "item": [
                {
                    "name": "Get All Items (by vehicleTypeId)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/equipment-items?vehicleTypeId=1",
                            "host": ["{{baseUrl}}"],
                            "path": ["equipment-items"],
                            "query": [{ "key": "vehicleTypeId", "value": "1" }]
                        },
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
                    }
                },
                {
                    "name": "Create Equipment Item (GOD)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/equipment-items",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Багатофункціональний інструмент рятувальника\",\n  \"norm\": 1,\n  \"brigadeNorm\": 2,\n  \"vehicleTypeId\": 1\n}"
                        }
                    }
                },
                {
                    "name": "Update Equipment Item (GOD)",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/equipment-items/1",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"name\": \"Updated name\",\n  \"norm\": 2\n}"
                        }
                    }
                },
                {
                    "name": "Delete Equipment Item (GOD)",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/equipment-items/1",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
                    }
                }
            ]
        },
        {
            "name": "Equipment Availability",
            "item": [
                {
                    "name": "Get Availability (by brigade + vehicleType)",
                    "request": {
                        "method": "GET",
                        "url": {
                            "raw": "{{baseUrl}}/equipment-availability?brigadeId=1&vehicleTypeId=1",
                            "host": ["{{baseUrl}}"],
                            "path": ["equipment-availability"],
                            "query": [
                                { "key": "brigadeId", "value": "1" },
                                { "key": "vehicleTypeId", "value": "1" }
                            ]
                        },
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
                    }
                },
                {
                    "name": "Create Availability (RW/GOD)",
                    "request": {
                        "method": "POST",
                        "url": "{{baseUrl}}/equipment-availability",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"equipmentItemId\": 1,\n  \"brigadeId\": 1,\n  \"vehicleCount\": 5,\n  \"available\": 3\n}"
                        }
                    }
                },
                {
                    "name": "Update Availability (RW/GOD)",
                    "request": {
                        "method": "PUT",
                        "url": "{{baseUrl}}/equipment-availability/1",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] },
                        "header": [{ "key": "Content-Type", "value": "application/json" }],
                        "body": {
                            "mode": "raw",
                            "raw": "{\n  \"vehicleCount\": 10,\n  \"available\": 7\n}"
                        }
                    }
                },
                {
                    "name": "Delete Availability (GOD)",
                    "request": {
                        "method": "DELETE",
                        "url": "{{baseUrl}}/equipment-availability/1",
                        "auth": { "type": "bearer", "bearer": [{ "key": "token", "value": "{{token}}" }] }
                    }
                }
            ]
        }
    ]
}
